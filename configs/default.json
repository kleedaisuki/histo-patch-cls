{
  "data": {
    "image_root": "data/raw",
    "train_transform": "train_basic",
    "eval_transform": "eval_basic",
    "image": {
      "image_size": [
        50,
        50
      ],
      "mean": [
        0.5,
        0.5,
        0.5
      ],
      "std": [
        0.25,
        0.25,
        0.25
      ]
    },
    "split": {
      "val_ratio": 0.2,
      "seed": 42
    },
    "loader": {
      "batch_size": 64,
      "num_workers": 4,
      "pin_memory": true,
      "train_drop_last": true,
      "eval_drop_last": false,
      "use_weighted_sampler": false
    }
  },
  "model": {
    "backbone_name": "resnet18",
    "hidden_dim": 256,
    "dropout": 0.2,
    "pretrained": true,
    "freeze_backbone": false
  },
  "trainer": {
    "epochs": 10,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "threshold": 0.5,
    "device": null,
    "use_amp": false,
    "grad_clip_norm": null,
    "pos_weight": null,
    "log_every_n_steps": 50,
    "checkpoint_dir": "outputs/checkpoints",
    "save_checkpoint_each_epoch": true
  },
  "evaluator": {
    "threshold": 0.5,
    "device": null,
    "use_amp": false
  },
  "seed": {
    "seed": 42,
    "deterministic": false,
    "benchmark": false
  }
}
